# GitHub Settings
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# Path to your local git clone of the repo
REPO_LOCAL_PATH=/path/to/local/clone

# Orchestrator Settings
MAX_CONCURRENCY=3
COST_CEILING_USD=50

# An interactive settings menu appears at startup on a TTY (pre-filled from this
# file). Skip it for headless/CI/scheduled runs with NON_INTERACTIVE=true or the
# --no-menu flag; values then come from this file.
# NON_INTERACTIVE=false

# Fix→review loop cap: a fix is reworked up to this many times until tests+lint
# pass AND review has no blocking findings, else the PR is left for a human.
MAX_ITERATIONS=3

# Bug discovery (ADR 0001): scan the target repo and file new issues to process.
# DISCOVERY=true enables it; DISCOVERY_SCOPE is a free-text scope; DISCOVERY_MAX
# caps how many new issues are filed per run.
# DISCOVERY=false
# DISCOVERY_SCOPE=the whole codebase
# DISCOVERY_MAX=5

# Leave merges to a human by default. Set to true to auto-merge confirmed PRs.
AUTO_MERGE=false

# Worktree dependency install (CRITIQUE #3).
# PACKAGE_MANAGER overrides lockfile auto-detection (npm/pnpm/yarn/bun).
# EXTRA_TEST_DEPS installs deps not in the manifest; the manifest/lockfile are
# restored afterward so they never pollute the fix's PR diff. Default: none.
# PACKAGE_MANAGER=pnpm
# EXTRA_TEST_DEPS=vitest jsdom

# Fix-quality gates (applied per issue before a fix is confirmed).
# REQUIRE_TESTS: reject a fix that changes code but adds/modifies no test (default: true).
# LINT_COMMAND:  override the lint command; otherwise the repo's `lint` script is used if present.
# WAIT_FOR_CI:   wait for the PR's GitHub CI checks to go green before merging (default: false).
# CI_TIMEOUT_MS / CI_POLL_INTERVAL_MS: tune CI polling (defaults: 600000 / 15000).
# REQUIRE_TESTS=true
# LINT_COMMAND=npm run lint
# WAIT_FOR_CI=false

# Providers (Claude / Codex / Kimi) — see docs/adr/0006.
# DEFAULT_PROVIDER drives triage/refine/discovery; FIX_PROVIDER and
# REVIEW_PROVIDER override the fix and reviewer roles. Default: claude.
# DEFAULT_PROVIDER=claude
# FIX_PROVIDER=claude
# REVIEW_PROVIDER=codex

# Model tiers: severity picks strong (critical/high) vs fast (medium/low).
# Override a provider's tier defaults, or pin exact models for fix/review.
# CLAUDE_MODEL_STRONG=opus
# CLAUDE_MODEL_FAST=sonnet
# CODEX_MODEL_STRONG=gpt-5-codex
# KIMI_MODEL_STRONG=kimi-k2-0905-preview
# FIX_MODEL=
# REVIEW_MODEL=

# Provider binaries / auth.
# CLAUDE_BIN and CODEX_BIN override executable lookup.
# Kimi runs through the Claude CLI against Moonshot's Anthropic endpoint:
# MOONSHOT_API_KEY=your_moonshot_key_here
# KIMI_BASE_URL=https://api.moonshot.ai/anthropic

# Cost: token usage is priced via prices.json (USD per 1M tokens).
# MODEL_PRICES is an optional JSON override merged on top of prices.json.
# MODEL_PRICES={"opus":{"input":15,"output":75}}

# Code review: Greptile if a key is set, otherwise a review agent on
# REVIEW_PROVIDER. Set ENABLE_REVIEW=false to skip review entirely.
# ENABLE_REVIEW=true
# Greptile Integration (code review via API)
# Get your API key at https://app.greptile.com
GREPTILE_API_KEY=your_greptile_api_key_here
