# GitHub Settings
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# Path to your local git clone of the repo
REPO_LOCAL_PATH=/path/to/local/clone

# Orchestrator Settings
MAX_CONCURRENCY=3
COST_CEILING_USD=50

# Greptile Integration (code review via API)
# Get your API key at https://app.greptile.com
GREPTILE_API_KEY=your_greptile_api_key_here
